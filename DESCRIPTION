Package: Meanimiles
Title: Estimation of Meanimiles
Version: 0.1.0
Authors@R: c(
    person("Dieter", "Debrauwer", , "dieter.debrauwer@kuleuven.be", role = c("aut", "cre","cph"),
    comment=c(ORCID="0000-0002-0171-1045")),
     person("Irène", "Gijbels",, email = "irene.gijbels@kuleuven.be", role = "ctb",
